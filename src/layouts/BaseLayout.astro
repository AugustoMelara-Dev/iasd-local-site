---
import "../styles/global.css";
import SEOHead from "../components/seo/SEOHead.astro";
import JsonLdChurch from "../components/seo/JsonLdChurch.astro";
import SiteHeader from "../components/navigation/SiteHeader.astro";
import SiteFooter from "../components/navigation/SiteFooter.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  noindex?: boolean;
  publishedDate?: Date;
  modifiedDate?: Date;
  author?: string;
}

const { title, description, image, type, noindex = false, publishedDate, modifiedDate, author } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <SEOHead
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      publishedDate={publishedDate}
      modifiedDate={modifiedDate}
      author={author}
    />
    <JsonLdChurch />
  </head>
  <body class="min-h-screen overflow-x-hidden bg-paper text-ink-900">
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <SiteHeader />
    <main id="contenido" class="min-h-[60vh]">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
