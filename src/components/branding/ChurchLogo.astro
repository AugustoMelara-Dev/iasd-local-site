---
import { churchInfo } from "../../data/site";

interface Props {
  variant?: "full" | "mark";
  class?: string;
}

const { variant = "full", class: className = "" } = Astro.props;

const src = variant === "mark" ? churchInfo.logo.markPath ?? churchInfo.logo.primaryPath : churchInfo.logo.primaryPath;
const alt = variant === "mark" ? "" : churchInfo.logo.alt;
---

<div class:list={["flex items-center", className]}>
  <img
    src={src}
    alt={alt}
    width={variant === "mark" ? 52 : churchInfo.logo.width}
    height={variant === "mark" ? 52 : churchInfo.logo.height}
    loading="eager"
    decoding="async"
    class:list={[
      "h-auto object-contain",
      variant === "mark" ? "w-11 sm:w-12" : "max-h-14 w-auto max-w-[240px]",
    ]}
  />
</div>
