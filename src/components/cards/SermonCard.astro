---
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  date: string;
  tags?: string[];
  passage?: string;
}

const { href, title, description, date, tags = [], passage } = Astro.props;
---

<Card>
  <p class="text-sm uppercase tracking-[0.2em] text-ink-500">{date}</p>
  <h3 class="mt-4 font-serif text-2xl text-ink-900">
    <a href={href}>{title}</a>
  </h3>
  <p class="mt-3 text-ink-600">{description}</p>
  {passage && <p class="mt-4 text-sm font-medium text-brand-800">{passage}</p>}
  <div class="mt-5 flex flex-wrap gap-2">
    {tags.slice(0, 3).map((tag) => <Badge>{tag}</Badge>)}
  </div>
</Card>
