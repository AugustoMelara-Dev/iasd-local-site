---
import Card from "../ui/Card.astro";
import Button from "../ui/Button.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  date: string;
  location?: string;
  registrationUrl?: string;
}

const { href, title, description, date, location, registrationUrl } = Astro.props;
---

<Card>
  <p class="text-sm uppercase tracking-[0.2em] text-ink-500">{date}</p>
  <h3 class="mt-4 font-serif text-2xl text-ink-900"><a href={href}>{title}</a></h3>
  <p class="mt-3 text-ink-600">{description}</p>
  {location && <p class="mt-4 text-sm text-brand-800">{location}</p>}
  <div class="mt-6 flex gap-3">
    <Button href={href} variant="ghost">Ver detalle</Button>
    {registrationUrl && <Button href={registrationUrl}>Registrarse</Button>}
  </div>
</Card>
