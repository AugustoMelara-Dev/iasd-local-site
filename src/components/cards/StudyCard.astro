---
import Card from "../ui/Card.astro";
import Badge from "../ui/Badge.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  topic: string;
  tags?: string[];
}

const { href, title, description, topic, tags = [] } = Astro.props;
---

<Card>
  <Badge>{topic}</Badge>
  <h3 class="mt-4 font-serif text-2xl text-ink-900"><a href={href}>{title}</a></h3>
  <p class="mt-3 text-ink-600">{description}</p>
  <div class="mt-5 flex flex-wrap gap-2 text-sm text-ink-500">
    {tags.map((tag) => <span>{tag}</span>)}
  </div>
</Card>
