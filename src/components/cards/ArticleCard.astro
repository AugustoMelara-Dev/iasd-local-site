---
import Card from "../ui/Card.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  category?: string;
  date: string;
}

const { href, title, description, category, date } = Astro.props;
---

<Card>
  <p class="text-sm uppercase tracking-[0.2em] text-ink-500">
    {category ? `${category} · ${date}` : date}
  </p>
  <h3 class="mt-4 font-serif text-2xl text-ink-900"><a href={href}>{title}</a></h3>
  <p class="mt-3 text-ink-600">{description}</p>
</Card>
