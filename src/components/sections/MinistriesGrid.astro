---
import Container from "../ui/Container.astro";
import Section from "../ui/Section.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";
import MinistryCard from "../cards/MinistryCard.astro";
import { getOrderedContent } from "../../lib/content";

const { ministries } = await getOrderedContent();
---

<Section>
  <Container>
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionHeading
        kicker="Ministerios"
        title="Areas de servicio para ninos, jovenes, familias y comunidad."
        description="La base del sitio permite comunicar responsable, horario y proposito de cada ministerio."
      />
      <Button href="/ministerios" variant="ghost">Ver ministerios</Button>
    </div>
    <div class="mt-10 grid gap-6 lg:grid-cols-3">
      {ministries.slice(0, 3).map((item) => <MinistryCard {...item.data} />)}
    </div>
  </Container>
</Section>
