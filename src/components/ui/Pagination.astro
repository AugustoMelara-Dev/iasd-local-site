---
interface Props {
  currentPage?: number;
  totalPages?: number;
}

const { currentPage = 1, totalPages = 1 } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="mt-10 flex items-center justify-center gap-3 text-sm text-ink-600">
      <span>Pagina {currentPage} de {totalPages}</span>
    </nav>
  )
}
