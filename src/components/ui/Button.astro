---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  type?: "button" | "submit";
  class?: string;
}

const { href, variant = "primary", type = "button", class: className = "" } = Astro.props;

const styles = {
  primary:
    "bg-brand-700 text-white shadow-soft hover:bg-brand-800 focus-visible:bg-brand-800",
  secondary:
    "bg-white text-ink-900 ring-1 ring-brand-200 hover:bg-brand-50 focus-visible:bg-brand-50",
  ghost:
    "bg-transparent text-brand-800 ring-1 ring-brand-200 hover:bg-brand-50 focus-visible:bg-brand-50",
};
---

{
  href ? (
    <a href={href} class={`btn ${styles[variant]} ${className}`}>
      <slot />
    </a>
  ) : (
    <button type={type} class={`btn ${styles[variant]} ${className}`}>
      <slot />
    </button>
  )
}
