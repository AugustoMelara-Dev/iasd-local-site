---
interface Props {
  kicker?: string;
  title: string;
  description?: string;
  centered?: boolean;
}

const { kicker, title, description, centered = false } = Astro.props;
---

<div class:list={["max-w-3xl", centered && "mx-auto text-center"]}>
  {kicker && <p class="section-kicker">{kicker}</p>}
  <h2 class="font-serif text-3xl text-ink-900 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-8 text-ink-600">{description}</p>}
</div>
