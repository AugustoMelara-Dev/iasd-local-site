---
import Button from "../ui/Button.astro";
import FormNotice from "./FormNotice.astro";
---

<form action="/api/contact" method="POST" class="surface-panel p-6 sm:p-8">
  <FormNotice />
  <div class="grid gap-5 md:grid-cols-2">
    <label class="grid gap-2 text-sm font-medium text-ink-700">
      Nombre
      <input name="name" autocomplete="name" required class="rounded-2xl border border-brand-100 px-4 py-3" />
    </label>
    <label class="grid gap-2 text-sm font-medium text-ink-700">
      Correo electronico
      <input type="email" name="email" autocomplete="email" inputmode="email" spellcheck="false" required class="rounded-2xl border border-brand-100 px-4 py-3" />
    </label>
    <label class="grid gap-2 text-sm font-medium text-ink-700 md:col-span-2">
      Motivo
      <input name="subject" autocomplete="off" required class="rounded-2xl border border-brand-100 px-4 py-3" />
    </label>
    <label class="grid gap-2 text-sm font-medium text-ink-700 md:col-span-2">
      Mensaje
      <textarea name="message" rows="6" autocomplete="off" placeholder="Comparte tu mensaje…" required class="rounded-2xl border border-brand-100 px-4 py-3"></textarea>
    </label>
    <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
  </div>
  <div class="mt-6">
    <Button type="submit">Enviar mensaje</Button>
  </div>
</form>
