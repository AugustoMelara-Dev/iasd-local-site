---
import Button from "../ui/Button.astro";
import FormNotice from "./FormNotice.astro";
---

<form action="/api/prayer" method="POST" class="surface-panel p-6 sm:p-8">
  <FormNotice />
  <div class="grid gap-5">
    <label class="grid gap-2 text-sm font-medium text-ink-700">
      Nombre
      <input name="name" autocomplete="name" required class="rounded-2xl border border-brand-100 px-4 py-3" />
    </label>
    <label class="grid gap-2 text-sm font-medium text-ink-700">
      Correo electronico
      <input type="email" name="email" autocomplete="email" inputmode="email" spellcheck="false" required class="rounded-2xl border border-brand-100 px-4 py-3" />
    </label>
    <label class="grid gap-2 text-sm font-medium text-ink-700">
      Peticion de oracion
      <textarea name="message" rows="6" autocomplete="off" placeholder="Escribe tu peticion de oracion…" required class="rounded-2xl border border-brand-100 px-4 py-3"></textarea>
    </label>
    <label class="inline-flex items-start gap-3 text-sm text-ink-600">
      <input type="checkbox" name="private" value="yes" class="mt-1" />
      Solicito que esta peticion sea tratada con caracter privado.
    </label>
    <input type="text" name="website" class="hidden" tabindex="-1" autocomplete="off" />
  </div>
  <div class="mt-6">
    <Button type="submit">Enviar peticion</Button>
  </div>
</form>
