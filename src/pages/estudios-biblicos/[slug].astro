---
import { getCollection } from "astro:content";
import ContentLayout from "../../layouts/ContentLayout.astro";

export async function getStaticPaths() {
  const items = await getCollection("studies", ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<ContentLayout
  title={item.data.title}
  description={item.data.description}
  typeLabel="Estudio biblico"
  author="Equipo de estudios biblicos"
  publishedDate={item.data.pubDate}
  modifiedDate={item.data.updatedDate}
  dateLabel={item.data.pubDate.toLocaleDateString("es-HN", { day: "numeric", month: "long", year: "numeric" })}
  breadcrumbs={[{ href: "/estudios-biblicos", label: "Estudios biblicos" }, { href: `/estudios-biblicos/${item.slug}/`, label: item.data.title }]}
>
  <Content />
</ContentLayout>
