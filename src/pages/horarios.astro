---
import PageLayout from "../layouts/PageLayout.astro";
import Container from "../components/ui/Container.astro";
import Section from "../components/ui/Section.astro";
import { getEntry } from "astro:content";

const settings = await getEntry("settings", "site");
---

<PageLayout title="Horarios" description="Resumen claro de reuniones regulares y observaciones." kicker="Informacion practica">
  <Section class="pb-20">
    <Container>
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {settings?.data.serviceTimes.map((item) => (
          <article class="card">
            <h2 class="font-serif text-3xl text-ink-900">{item.name}</h2>
            <p class="mt-3 text-brand-800">{item.schedule}</p>
            {item.notes && <p class="mt-4 text-ink-600">{item.notes}</p>}
          </article>
        ))}
      </div>
    </Container>
  </Section>
</PageLayout>
